<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:dither="true" android:shape="rectangle">
            <padding android:left="1.0px" android:right="1.0px" android:bottom="1.0px" />
            <solid android:color="#ffffff" />
            <stroke android:width="1.0px" android:color="#eceff0" />
        </shape>
    </item>
    <item android:left="-2.0px" android:top="-2.0px" android:right="-2.0px">
        <shape android:dither="true" android:shape="rectangle">
            <padding android:bottom="1.0px" />
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1.0px" android:color="#dbdedf" />
        </shape>
    </item>
</layer-list>
