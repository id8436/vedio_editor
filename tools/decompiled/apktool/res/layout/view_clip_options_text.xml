<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:id="@id/textBody" android:layout_width="match_parent" android:layout_height="match_parent" android:fadeScrollbars="false"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/clipOptionsBodyStyle">
        <TextView android:id="@id/titleText" android:paddingLeft="10.0dp" android:paddingBottom="5.0dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/title_text_title" />
        <FrameLayout android:background="#000000" android:padding="1.0dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="10.0dp" android:layout_marginRight="10.0dp" android:layout_marginBottom="5.0dp">
            <ScrollView android:id="@id/textScrollView" android:background="#ffffff" android:layout_width="match_parent" android:layout_height="@dimen/title_text_box_height" android:onClick="showStoryCardInputDialog">
                <TextView android:textSize="16.0sp" android:id="@id/titleTextView" android:background="@drawable/ripple_effect_2" android:padding="5.0dp" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="@dimen/title_text_box_height" android:text="@string/title_image_default_title" android:onClick="showTitleTextInputDialog" />
