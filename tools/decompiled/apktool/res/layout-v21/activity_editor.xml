        <RelativeLayout android:id="@id/track_name_ui" android:background="#ffffff" android:layout_width="match_parent" android:layout_height="@dimen/clip_option_btn_size" android:layout_marginLeft="10.0dp" android:layout_marginRight="10.0dp" android:layout_below="@id/music_top">
