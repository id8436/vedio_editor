    <View android:id="@id/background_for_fab" android:background="#77000000" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:onClick="closeFAB" />
    <com.getbase.floatingactionbutton.FloatingActionsMenu android:id="@id/add_clip_btn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="8.0dp" android:layout_marginBottom="8.0dp" android:layout_alignParentRight="true" android:layout_alignParentBottom="true" fab:fab_addButtonColorPressed="@color/primary" fab:fab_addButtonColorNormal="@color/primary" fab:fab_addButtonPlusIconColor="#ffffff" fab:fab_labelStyle="@style/menu_labels_style" />
    <include layout="@layout/bottom_sheet_options_editor" />
    <include layout="@layout/sharing_options" />
    <include layout="@layout/view_media_capture_options" />
    <View android:id="@id/touch_guard" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" />
</RelativeLayout>
