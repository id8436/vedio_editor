                <TextView android:textColor="#aaa" android:id="@id/preview_time_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="10.0dp" android:layout_marginBottom="5.0dp" android:text="" android:layout_below="@id/preview_seek_bar" android:layout_alignParentLeft="true" android:layout_alignParentBottom="true" />
                <TextView android:textColor="#aaa" android:id="@id/preview_duration_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="10.0dp" android:layout_marginBottom="5.0dp" android:text="" android:layout_below="@id/preview_seek_bar" android:layout_alignParentRight="true" android:layout_alignParentBottom="true" />
