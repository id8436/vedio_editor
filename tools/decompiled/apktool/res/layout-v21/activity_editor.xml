                <ImageView android:id="@id/editorPreviewShareBtn" android:padding="6.0dp" android:src="@drawable/proj_share_white" android:layout_toLeftOf="@id/editorPreviewCollapseBtn" android:layout_centerVertical="true" style="@style/EditorIconStyle" />
