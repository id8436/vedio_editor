<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@color/bsdk_card_color"
    android:layout_width="@dimen/bsdk_generic_alert_dialog_width"
    android:layout_height="wrap_content">
    <TextView
        android:layout_gravity="start"
        android:id="@+id/bsdk_unfollowDialogTitleTxtView"
        style="@style/BsdkDialogTitleText"/>
    <LinearLayout
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="8dp">
        <Button
            android:id="@+id/bsdk_unfollowButton"
            android:text="@string/bsdk_unfollow"
            style="@style/BsdkDialogActionButtonStyle"/>
    </LinearLayout>
</LinearLayout>
