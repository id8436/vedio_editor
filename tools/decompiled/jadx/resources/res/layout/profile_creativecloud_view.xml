<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    card_view:cardBackgroundColor="#ffffff"
    card_view:cardCornerRadius="@dimen/card_corner_radius"
    card_view:cardElevation="@dimen/card_elevation">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13.33sp"
                android:textColor="@color/settings_dark_text"
                android:id="@+id/sync_location_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:text="@string/settings_sync_location"
                android:layout_alignParentLeft="true"
                android:layout_centerInParent="true"/>
            <TextView
                android:textSize="13.33sp"
                android:textColor="@color/settings_secondary"
                android:id="@+id/cloud_selection_text"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:text="@string/settings_change_cloud"
                android:layout_alignParentRight="true"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
            android:layout_marginTop="8dp">
            <com.sage42.android.view.ui.CircularProgressBar
                android:textSize="13.33sp"
                android:textColor="@color/settings_primary"
                android:id="@+id/storageUsageProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentLeft="true"
                card_view:showText="false"
                card_view:max="100"
                card_view:bgColor="#e4e2e5"
                card_view:progressColor="@color/settings_primary"
                card_view:bgStrokeWidth="7.67dp"
                card_view:progressStrokeWidth="7.67dp"
                card_view:diameter="71.67dp"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="87.33dp"
                android:layout_marginLeft="36dp"
                android:layout_toRightOf="@+id/storageUsageProgressBar"
                android:layout_centerVertical="true">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:id="@+id/private_cloud_info"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="6dp"
                    android:layout_centerVertical="true">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="@color/settings_dark_text"
                        android:id="@+id/profileSubscriptionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:layout_alignParentLeft="true"
                        android:layout_centerInParent="true"/>
                    <TextView
                        android:textSize="13.33sp"
                        android:textColor="@color/settings_light_text"
                        android:id="@+id/private_cloud_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:layout_alignParentLeft="true"
                        android:layout_centerInParent="true"/>
                </LinearLayout>
                <TextView
                    android:textSize="13.33sp"
                    android:textColor="@color/settings_dark_text"
                    android:id="@+id/storageInfoTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:singleLine="true"
                    android:layout_alignParentLeft="true"
                    android:layout_centerInParent="true"/>
            </LinearLayout>
        </RelativeLayout>
        <View
            android:id="@+id/profile_storage_view_divider"
            android:background="@color/settings_list_divider_color"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="46dp">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/settings_dark_text"
                android:id="@+id/backupOnMobileDataTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="14dp"
                android:text="@string/backup_option_mobile_data"
                android:layout_centerVertical="true"/>
            <android.support.v7.widget.SwitchCompat
                android:id="@+id/backupOnMobileDataSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="14dp"
                android:layout_alignParentRight="true"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
    </LinearLayout>
</android.support.v7.widget.CardView>
