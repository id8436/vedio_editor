<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/bsdk_card_color"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:background="@color/bsdk_comments_view_item_divider_color"
        android:layout_width="match_parent"
        android:layout_height="0.67dp"
        android:layout_marginLeft="66.33dp"
        android:layout_marginRight="15dp"
        android:layout_alignParentBottom="true"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/bsdk_card_project_comment_container"
        android:background="?attr/selectableItemBackground"
        android:paddingLeft="15dp"
        android:paddingTop="16.33dp"
        android:paddingRight="15dp"
        android:paddingBottom="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/bsdk_card_project_comment_avatar"
            android:layout_width="@dimen/bsdk_comments_view_commenter_image_width_height"
            android:layout_height="@dimen/bsdk_comments_view_commenter_image_width_height"
            android:layout_marginTop="2.33dp"
            android:scaleType="fitXY"
            android:contentDescription="@string/bsdk_msg_image_missing"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="11.33dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/bsdk_comments_view_item_txt_color"
                    android:id="@+id/bsdk_card_project_comment_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="11.33sp"
                    android:textColor="@color/bsdk_comments_view_item_date_txt_color"
                    android:id="@+id/bsdk_card_project_comment_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/bsdk_comments_view_item_txt_color"
                android:textColorLink="@color/bsdk_app_default_hyper_links_txt_color"
                android:autoLink="all"
                android:id="@+id/bsdk_card_project_comment_comment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="1.33dp"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
