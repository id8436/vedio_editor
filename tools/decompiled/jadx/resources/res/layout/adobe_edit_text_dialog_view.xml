<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/adobe_csdk_actionbar_background_color"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:weightSum="100"
    android:minWidth="160dp"
    android:minHeight="150dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="20">
        <com.adobe.creativesdk.foundation.internal.utils.CreativeSDKTextView
            android:textSize="18sp"
            android:textColor="@color/adobe_csdk_no_preview_color"
            android:id="@+id/adobe_cc_edit_text_dialog_box_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:maxLines="1"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/adobe_cc_edit_text_margin_top"
        android:layout_weight="40">
        <com.adobe.creativesdk.foundation.internal.utils.CreativeSDKEditText
            android:textColor="@color/adobe_csdk_grayText"
            android:textColorHint="#d9dbdd"
            android:ellipsize="middle"
            android:id="@+id/adobe_cc_edit_text_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="15dp"
            android:layout_marginRight="30dp"
            android:ems="@integer/adobe_csdk_dialog_ems"
            android:maxLength="255"
            android:inputType="textNoSuggestions"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/adobe_cc_edit_text_error_container"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp">
            <com.adobe.creativesdk.foundation.internal.utils.CreativeSDKTextView
                android:textSize="@dimen/adobe_csdk_assetview_dialog_error_text_size"
                android:textColor="@color/adobe_csdk_assetview_common_error_banner_background"
                android:ellipsize="middle"
                android:gravity="center_horizontal"
                android:id="@+id/adobe_cc_edit_text_error_text"
                android:background="@color/adobe_csdk_transparent_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/adobe_csdk_assetview_dialog_fragment_layout_height"
        android:layout_marginBottom="4dp"
        android:layout_weight="100">
        <ProgressBar
            android:id="@+id/adobe_cc_edit_text_progressbar"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp"
            android:layout_marginRight="@dimen/adobe_csdk_dialog_fragment_progress_margin_right"
            android:layout_marginBottom="5dp"
            android:progress="100"
            android:layout_toLeftOf="@+id/buttons_layout"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/buttons_layout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="2dp"
            android:layout_marginRight="20dp"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true">
            <com.adobe.creativesdk.foundation.internal.utils.CreativeSDKTextView
                android:textSize="18sp"
                android:textColor="@color/adobe_csdk_grayText"
                android:gravity="center"
                android:id="@+id/adobe_cc_edit_text_negative_button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/adobe_csdk_asset_view_edit_rename_dialog_negative_button"/>
            <RelativeLayout
                android:layout_width="25dp"
                android:layout_height="match_parent"/>
            <com.adobe.creativesdk.foundation.internal.utils.CreativeSDKTextView
                android:textSize="18sp"
                android:textColor="@color/adobe_csdk_blue_color"
                android:gravity="center"
                android:id="@+id/adobe_cc_edit_text_positive_button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/adobe_csdk_asset_view_edit_rename_dialog_positive_button"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
