<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="4dp"
    android:layout_marginTop="4dp"
    android:layout_marginRight="4dp"
    android:layout_marginBottom="4dp">
    <RelativeLayout
        android:id="@+id/gallery_media_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp">
        <ImageView
            android:id="@+id/gallery_media_thumb"
            android:background="@color/white"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <CheckedTextView
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:textColorHint="#ff6f36a0"
            android:id="@+id/gallery_media_checkmark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkMark="@drawable/btn_picker_check_2x"
            android:layout_centerInParent="true"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"/>
        <TextView
            android:textColor="@color/white"
            android:gravity="right"
            android:id="@+id/gallery_media_time"
            android:background="@null"
            android:layout_width="60dp"
            android:layout_height="20dp"
            android:layout_marginRight="4dp"
            android:layout_marginBottom="4dp"
            android:shadowColor="@color/black"
            android:shadowDx="2"
            android:shadowDy="4"
            android:shadowRadius="10"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <TextView
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/media_title"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:singleLine="true"
        android:layout_below="@+id/gallery_media_layout"
        android:layout_alignParentBottom="true"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"/>
    <ImageView
        android:id="@+id/gallery_active_media_frame"
        android:background="#80ffffff"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/active_clip_frame"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
