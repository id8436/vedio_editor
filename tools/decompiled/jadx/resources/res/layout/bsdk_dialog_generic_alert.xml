<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bsdk_shape_generic_alert_dialog_content_bg"
    android:layout_width="@dimen/bsdk_generic_alert_dialog_width"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/bsdkGenericAlertDialogTitleTxtView"
        style="@style/BsdkDialogTitleText"/>
    <TextView
        android:textSize="@dimen/bsdk_generic_alert_dialog_content_txt_size"
        android:textColor="@color/bsdk_generic_alert_dialog_content_text_color"
        android:id="@+id/bsdkGenericAlertDialogBodyTxtView"
        android:paddingLeft="21.33dp"
        android:paddingTop="6dp"
        android:paddingRight="21.33dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:singleLine="false"
        android:fontFamily="sans-serif-light"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="8dp">
        <Button
            android:id="@+id/bsdkGenericAlertDialogNotOKBtn"
            android:text="@string/bsdk_new_message_thread_view_discard_msg_confirmation_cancel_btn_label"
            style="@style/BsdkDialogActionButtonStyle"/>
        <Button
            android:id="@+id/bsdkGenericAlertDialogOKBtn"
            android:text="@string/bsdk_new_message_thread_view_discard_msg_confirmation_discard_btn_label"
            style="@style/BsdkDialogActionButtonStyle"/>
    </LinearLayout>
</LinearLayout>
