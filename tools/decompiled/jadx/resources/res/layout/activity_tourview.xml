<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/black"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <android.support.v4.view.ViewPager
                android:id="@+id/pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <com.viewpagerindicator.CirclePageIndicator
                android:id="@+id/circlePageIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/tour_view_page_indicator_margin_bottom"
                android:layout_alignParentBottom="true"
                app:strokeWidth="0dp"
                app:fillColor="@color/tour_view_page_indicator_fill_color"
                app:pageColor="@color/tour_view_page_indicator_page_color"
                app:radius="@dimen/tour_view_page_indicator_radius"
                app:snap="true"
                app:strokeColor="@color/tour_view_page_indicator_stroke_color"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ccButtonLayout"
            android:background="#ffffff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="1">
            <Button
                android:textColor="@color/tour_view_sign_up_button_text_color"
                android:id="@+id/signUpButton"
                android:background="@color/tour_view_sign_up_button_background_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_title_sign_up"
                android:layout_weight="0.5"
                style="@style/tourViewButtonStyle"/>
            <Button
                android:textColor="@color/tour_view_sign_in_button_text_color"
                android:id="@+id/loginButton"
                android:background="@color/tour_view_sign_in_button_background_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_title_sign_in"
                android:layout_weight="0.5"
                style="@style/tourViewButtonStyle"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/spinner_background"
        android:background="@color/coachmark_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/tourview_spinner"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/btn_spinner"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
</RelativeLayout>
