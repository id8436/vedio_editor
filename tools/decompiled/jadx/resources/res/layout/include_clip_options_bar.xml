<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clip_options"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="@dimen/clip_option_btn_size"
    android:layout_below="@+id/top_bar">
    <android.support.design.widget.TabLayout
        android:id="@+id/clip_options_tablayout"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:tabIndicatorHeight="@dimen/clip_option_bar_height"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabMaxWidth="0dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/dummy_clip_options_tabs"
        android:paddingBottom="@dimen/clip_option_bar_height"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false">
        <FrameLayout
            android:id="@+id/exposureBtn"
            android:background="@drawable/ripple_effect_purple"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:onClick="onClickExposureOption">
            <ImageView
                android:id="@+id/exposureBtnImg"
                android:background="@null"
                android:src="@drawable/btn_exposure_purple"
                style="@style/clipOptionsBtnStyle2"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/audioBtn"
            android:background="@drawable/ripple_effect_purple"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:onClick="onClickAudioOption">
            <ImageView
                android:id="@+id/audioBtnImg"
                android:background="@null"
                android:src="@drawable/btn_volume_purple"
                style="@style/clipOptionsBtnStyle2"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/textBtn"
            android:background="@drawable/ripple_effect_purple"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:onClick="onClickTextOption">
            <ImageView
                android:id="@+id/textBtnImg"
                android:background="@null"
                android:src="@drawable/btn_picker_title"
                style="@style/clipOptionsBtnStyle2"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/moreBtn"
            android:background="@drawable/ripple_effect_purple"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:onClick="onClickMoreOption">
            <ImageView
                android:id="@+id/moreBtnImg"
                android:background="@null"
                android:src="@drawable/btn_adjust_purple"
                style="@style/clipOptionsBtnStyle2"/>
        </FrameLayout>
    </LinearLayout>
</RelativeLayout>
