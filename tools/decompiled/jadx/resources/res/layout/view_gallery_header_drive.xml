<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/gallery_header_background"
    android:paddingBottom="10dp"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="4dp"
    android:layout_marginTop="4dp"
    android:layout_marginRight="4dp"
    android:layout_marginBottom="4dp">
    <ImageView
        android:id="@+id/header_media_thumb"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp"
        android:layout_width="@dimen/header_thumb_size"
        android:layout_height="@dimen/header_thumb_size"
        android:layout_marginLeft="2dp"
        android:src="@drawable/soundtrack_folder"
        android:scaleType="centerCrop"
        android:layout_centerVertical="true"/>
    <TextView
        android:textSize="16sp"
        android:ellipsize="end"
        android:id="@+id/text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_toRightOf="@+id/header_media_thumb"
        android:layout_centerInParent="true"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:textDirection="locale"
        android:layoutDirection="locale"/>
</RelativeLayout>
