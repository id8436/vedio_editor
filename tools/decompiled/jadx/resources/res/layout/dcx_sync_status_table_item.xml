<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:gravity="top"
        android:id="@+id/dcx_sync_project_poster"
        android:layout_width="120dp"
        android:layout_height="70dp"
        android:src="@drawable/gra_projectthumb_placeholder"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp">
        <TextView
            android:textStyle="bold"
            android:id="@+id/dcx_sync_project_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/dcx_sync_upload_media_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/dcx_sync_download_media_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/cc_asset_download_media_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/dcx_sync_project_sync_completed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dcx_sync_completed"/>
    </LinearLayout>
</LinearLayout>
