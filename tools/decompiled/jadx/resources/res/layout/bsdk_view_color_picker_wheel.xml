<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.behance.sdk.ui.components.BehanceSDKGradientSeekBar
        android:id="@+id/bsdk_color_picker_gradient_seek"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="3"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="18">
        <com.behance.sdk.ui.customviews.BehanceSDKColorWheelLayer
            android:id="@+id/bsdk_color_picker_wheel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"/>
        <com.behance.sdk.ui.customviews.BehanceSDKColorWheelPickerLayer
            android:id="@+id/bsdk_color_picker_picker"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <View
        android:id="@+id/bsdk_color_picker_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginBottom="4dp"
        android:layout_weight="3"/>
</LinearLayout>
