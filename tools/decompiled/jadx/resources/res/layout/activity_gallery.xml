<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <android.support.v7.widget.Toolbar
        android:id="@+id/top_bar"
        android:background="?attr/colorPrimary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/editor_topbar_height">
        <ImageView
            android:id="@+id/gallery_back_button"
            style="@style/backIconStyle"/>
        <LinearLayout
            android:id="@+id/gallery_name_toolbar"
            android:background="@drawable/ripple_effect_white"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_toRightOf="@+id/gallery_back_button"
            android:layout_centerVertical="true">
            <TextView
                android:textSize="16sp"
                android:textColor="#ffffff"
                android:layout_gravity="center"
                android:id="@+id/gallery_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:maxWidth="170dp"
                android:text="Google Photos"
                android:singleLine="true"
                android:layout_marginStart="10dp"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/drop_down"
                android:background="@drawable/ic_arrow_drop_down_white_24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </android.support.v7.widget.Toolbar>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/top_bar">
        <android.support.v7.widget.RecyclerView
            android:id="@+id/gallery_list"
            android:scrollbars="vertical"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/clip_thumb_margin"
            android:layout_marginTop="@dimen/clip_thumb_margin"/>
        <RelativeLayout
            android:orientation="vertical"
            android:id="@+id/textViewLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="20sp"
                android:textColor="#a2a2a2"
                android:gravity="center"
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="8dp"
                android:layout_above="@+id/signInButton"/>
            <Button
                android:textColor="#fffefefe"
                android:id="@+id/signInButton"
                android:background="@drawable/round_button"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:text="@string/google_sign_in"
                android:layout_centerInParent="true"
                android:layout_centerHorizontal="true"
                android:textAllCaps="false"
                style="@style/clipButtonStyle"/>
        </RelativeLayout>
    </RelativeLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50sp"
        android:layout_alignParentBottom="true">
        <Button
            android:textSize="18sp"
            android:textColor="#ffffff"
            android:id="@+id/gallery_done"
            android:background="@drawable/ripple_purple_button"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="5dp"
            android:tint="#ffffff"
            android:text="@string/gallery_done"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            style="?android:attr/borderlessButtonStyle"/>
    </LinearLayout>
</RelativeLayout>
