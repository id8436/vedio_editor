<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/textBody"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fadeScrollbars="false">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/clipOptionsBodyStyle">
        <TextView
            android:id="@+id/titleText"
            android:paddingLeft="10dp"
            android:paddingBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_text_title"/>
        <FrameLayout
            android:background="#000000"
            android:padding="1dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="5dp">
            <ScrollView
                android:id="@+id/textScrollView"
                android:background="#ffffff"
                android:layout_width="match_parent"
                android:layout_height="@dimen/title_text_box_height"
                android:onClick="showStoryCardInputDialog">
                <TextView
                    android:textSize="16sp"
                    android:id="@+id/titleTextView"
                    android:background="@drawable/ripple_effect_2"
                    android:padding="5dp"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/title_text_box_height"
                    android:text="@string/title_image_default_title"
                    android:onClick="showTitleTextInputDialog"/>
            </ScrollView>
        </FrameLayout>
        <View
            android:id="@+id/text_seperator1"
            android:background="@color/clip_options_seperator_color"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="5dp"/>
        <RelativeLayout
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/textColorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text_color_title"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"/>
            <FrameLayout
                android:background="#999999"
                android:padding="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true">
                <FrameLayout
                    android:id="@+id/textColor"
                    android:background="#ffffff"
                    android:layout_width="@dimen/color_box_wide_width"
                    android:layout_height="@dimen/color_box_height">
                    <View
                        android:background="@drawable/ripple_effect_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:onClick="pickTextColor"/>
                </FrameLayout>
            </FrameLayout>
        </RelativeLayout>
        <View
            android:id="@+id/text_seperator2"
            android:background="@color/clip_options_seperator_color"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>
        <RelativeLayout
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/backgroundColorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/background_color_title"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"/>
            <FrameLayout
                android:background="#999999"
                android:padding="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true">
                <FrameLayout
                    android:id="@+id/backgroundColor"
                    android:background="#000000"
                    android:layout_width="@dimen/color_box_wide_width"
                    android:layout_height="@dimen/color_box_height">
                    <View
                        android:background="@drawable/ripple_effect_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:onClick="pickBackgroundColor"/>
                </FrameLayout>
            </FrameLayout>
        </RelativeLayout>
    </LinearLayout>
</ScrollView>
