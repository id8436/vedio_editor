<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/subview_theme_list"
        android:background="@color/theme_color"
        android:layout_width="match_parent"
        android:layout_height="@dimen/editor_topbar_height">
        <ImageView
            android:id="@+id/backButton"
            android:onClick="closeAndGoBack"
            style="@style/backIconStyle"/>
        <LinearLayout
            android:id="@+id/library_name_toolbar"
            android:background="@drawable/ripple_effect_white"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_toRightOf="@+id/backButton"
            android:layout_centerVertical="true">
            <TextView
                android:textSize="16sp"
                android:textColor="#ffffff"
                android:layout_gravity="center"
                android:id="@+id/lib_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:maxWidth="170dp"
                android:text="Clip Default Looks"
                android:singleLine="true"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/drop_down"
                android:background="@drawable/ic_arrow_drop_down_white_24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/player_container"
        android:background="#000"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"/>
    <RelativeLayout
        android:background="#ededed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <android.support.v7.widget.RecyclerView
            android:id="@+id/shapeImages_gridView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/look_item_padding"
            android:layout_marginTop="@dimen/look_item_padding"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/empty_library_text"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:layout_centerInParent="true">
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="@string/empty_library_title"/>
            <TextView
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empty_library_description"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
