<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginRight="@dimen/look_item_padding"
    android:layout_marginBottom="@dimen/look_item_padding">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/look_item_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="0dp"
                android:src="@drawable/gra_looks_pack"
                android:scaleType="centerCrop"/>
        </RelativeLayout>
        <TextView
            android:textColor="#000000"
            android:id="@+id/look_item_name"
            android:paddingLeft="@dimen/project_name_padding"
            android:paddingTop="@dimen/look_text_padding"
            android:paddingRight="@dimen/project_name_padding"
            android:paddingBottom="@dimen/look_text_padding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/active_look_frame"
        android:layout_width="match_parent"
        android:layout_height="@dimen/look_item_height"
        android:src="@drawable/square_frame"/>
    <ProgressBar
        android:id="@+id/look_loader"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"/>
</RelativeLayout>
