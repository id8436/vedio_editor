<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bsdk_shape_generic_alert_dialog_content_bg"
    android:layout_width="@dimen/bsdk_generic_alert_dialog_width"
    android:layout_height="wrap_content">
    <com.behance.sdk.ui.customviews.BehanceSDKTextView
        android:textSize="@dimen/bsdk_generic_alert_dialog_title_txt_size"
        android:textColor="@color/bsdk_generic_alert_dialog_title_text_color"
        android:id="@+id/bsdkAddProjectEmbedContentDialogHeader"
        android:background="@drawable/bsdk_shape_generic_alert_dialog_title_bg"
        android:paddingLeft="@dimen/bsdk_generic_alert_dialog_title_left_right_padding"
        android:paddingTop="@dimen/bsdk_generic_alert_dialog_title_top_bottom_padding"
        android:paddingRight="@dimen/bsdk_generic_alert_dialog_title_left_right_padding"
        android:paddingBottom="@dimen/bsdk_generic_alert_dialog_title_top_bottom_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bsdk_add_project_embed_content_title"
        android:maxLines="2"/>
    <com.behance.sdk.ui.customviews.BehanceSDKEditText
        android:textSize="@dimen/bsdk_generic_alert_dialog_content_txt_size"
        android:textColor="@color/bsdk_generic_alert_dialog_content_text_color"
        android:textColorHint="@color/bsdk_add_project_embed_content_dialog_embed_content_text_hint_color"
        android:layout_gravity="center_horizontal"
        android:id="@+id/bsdkAddProjectEmbedContentDialogContentTxt"
        android:background="@drawable/bsdk_selector_edit_text_behance_blue"
        android:paddingTop="@dimen/bsdk_add_project_embed_content_dialog_edit_txt_top_padding"
        android:paddingBottom="@dimen/bsdk_add_project_embed_content_dialog_edit_txt_bottom_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/bsdk_add_project_embed_content_dialog_edit_txt_left_margin"
        android:layout_marginRight="@dimen/bsdk_add_project_embed_content_dialog_edit_txt_right_margin"
        android:layout_marginBottom="@dimen/bsdk_add_project_embed_content_dialog_edit_txt_bottom_margin"
        android:hint="@string/bsdk_add_project_embed_content_edit_text_hint"
        android:singleLine="true"
        android:layout_below="@+id/bsdkAddProjectEmbedContentDialogHeader"
        android:imeOptions="flagNoFullscreen"/>
    <RelativeLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bsdk_generic_alert_dialog_buttons_container_height"
        android:layout_below="@+id/bsdkAddProjectEmbedContentDialogContentTxt">
        <View
            android:background="?android:attr/dividerVertical"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_alignParentTop="true"/>
        <View
            android:id="@+id/bsdkAddProjectEmbedContentDialogDividerForTransparentButton"
            android:background="?android:attr/dividerVertical"
            android:layout_width="1dp"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"/>
        <com.behance.sdk.ui.customviews.BehanceSDKButton
            android:textSize="@dimen/bsdk_generic_alert_dialog_buttons_txt_size"
            android:textColor="@color/bsdk_generic_alert_dialog_buttons_text_color"
            android:id="@+id/bsdkAddProjectEmbedContentDialogNotOKBtn"
            android:background="@drawable/bsdk_selector_app_default_selection_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bsdk_generic_alert_dialog_cancel_btn_label"
            android:layout_toLeftOf="@+id/bsdkAddProjectEmbedContentDialogDividerForTransparentButton"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_alignParentBottom="true"/>
        <com.behance.sdk.ui.customviews.BehanceSDKButton
            android:textSize="@dimen/bsdk_generic_alert_dialog_buttons_txt_size"
            android:textColor="@color/bsdk_generic_alert_dialog_buttons_text_color"
            android:id="@+id/bsdkAddProjectEmbedContentDialogOKBtn"
            android:background="@drawable/bsdk_selector_app_default_selection_bg"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/bsdk_generic_alert_dialog_ok_btn_label"
            android:layout_toRightOf="@+id/bsdkAddProjectEmbedContentDialogDividerForTransparentButton"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
</RelativeLayout>
