<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:background="@drawable/bsdk_bg_image_actionbar"
    android:layout_width="match_parent"
    android:layout_height="?android:attr/actionBarSize">
    <RelativeLayout
        android:id="@+id/bsdkPublishProjectPublishFragmentCustomTitleBarLeftNavLayout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentLeft="true">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/bsdkPublishProjectPublishFragmentTitlebarBackBtnLayout"
            android:background="@drawable/bsdk_selector_app_default_selection_bg"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerVertical="true">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/bsdkPublishProjectPublishFragmentTitlebarBackBtnImageView"
                android:paddingLeft="@dimen/bsdk_titlebar_left_margin"
                android:paddingRight="@dimen/bsdk_titlebar_back_button_right_margin"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:src="@drawable/bsdk_icon_actionbar_back_button"
                android:scaleType="center"
                android:contentDescription="@string/bsdk_wip_publish_view_titlebar_back_nav_content_desc"/>
        </LinearLayout>
        <com.behance.sdk.ui.customviews.BehanceSDKTextView
            android:textSize="@dimen/bsdk_titlebar_txt_size"
            android:textColor="@color/bsdk_titlebar_txt_color"
            android:id="@+id/bsdkPublishProjectPublishFragmentTitlebarTitleTxtView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/bsdkPublishProjectPublishFragmentTitlebarBackBtnLayout"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <com.behance.sdk.ui.customviews.BehanceSDKTextView
        android:textSize="@dimen/bsdk_titlebar_action_btn_txt_size"
        android:textColor="@color/bsdk_project_publish_view_titlebar_publish_btn_txt_color"
        android:gravity="center"
        android:id="@+id/bsdkPublishProjectPublishFragmentTitlebarActionBtnTxtView"
        android:background="@drawable/bsdk_selector_publish_project_action_bar_publish_btn_bg"
        android:paddingLeft="@dimen/bsdk_add_project_custom_actionbar_left_padding"
        android:paddingRight="@dimen/bsdk_add_project_custom_actionbar_right_padding"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginBottom="0.5dp"
        android:text="@string/bsdk_add_content_project_publish_right_navigation"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
