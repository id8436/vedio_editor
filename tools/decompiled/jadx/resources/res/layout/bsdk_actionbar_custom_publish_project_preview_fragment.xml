<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:background="@drawable/bsdk_bg_image_actionbar"
    android:layout_width="match_parent"
    android:layout_height="?android:attr/actionBarSize">
    <com.behance.sdk.ui.customviews.BehanceSDKTextView
        android:textSize="@dimen/bsdk_titlebar_action_btn_txt_size"
        android:textColor="@drawable/bsdk_selector_titlebar_action_btn_color"
        android:gravity="center_vertical"
        android:id="@+id/bsdkPublishProjectPreviewFragmentTitlebarActionBtnTxtView"
        android:paddingLeft="@dimen/bsdk_add_project_custom_actionbar_left_padding"
        android:paddingRight="@dimen/bsdk_add_project_custom_actionbar_right_padding"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentRight="true"/>
    <com.behance.sdk.ui.customviews.BehanceSDKTextView
        android:textSize="@dimen/bsdk_titlebar_action_btn_txt_size"
        android:textColor="@drawable/bsdk_selector_titlebar_action_btn_color"
        android:gravity="center_vertical"
        android:id="@+id/bsdkPublishProjectPreviewFragmentTitlebarEditActionBtnTxtView"
        android:paddingLeft="@dimen/bsdk_add_project_custom_actionbar_left_padding"
        android:paddingRight="@dimen/bsdk_add_project_custom_actionbar_right_padding"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginRight="@dimen/bsdk_add_project_custom_actionbar_edit_button_right_margin"
        android:text="@string/bsdk_add_project_preview_project_fragment_edit_action"
        android:layout_toLeftOf="@+id/bsdkPublishProjectPreviewFragmentTitlebarActionBtnTxtView"/>
    <RelativeLayout
        android:id="@+id/bsdkPublishProjectPreviewFragmentCustomTitleBarLeftNavLayout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_toLeftOf="@+id/bsdkPublishProjectPreviewFragmentTitlebarEditActionBtnTxtView"
        android:layout_alignParentLeft="true">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/bsdkPublishProjectPreviewFragmentTitlebarBackBtnLayout"
            android:background="@drawable/bsdk_selector_app_default_selection_bg"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerVertical="true">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/bsdkPublishProjectPreviewFragmentTitlebarBackBtnImageView"
                android:paddingLeft="@dimen/bsdk_titlebar_left_margin"
                android:paddingRight="@dimen/bsdk_titlebar_back_button_right_margin"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:src="@drawable/bsdk_icon_actionbar_back_button"
                android:scaleType="center"
                android:contentDescription="@string/bsdk_wip_publish_view_titlebar_back_nav_content_desc"/>
        </LinearLayout>
        <com.behance.sdk.ui.customviews.BehanceSDKTextView
            android:textSize="@dimen/bsdk_titlebar_txt_size"
            android:textColor="@color/bsdk_titlebar_txt_color"
            android:ellipsize="end"
            android:id="@+id/bsdkPublishProjectPreviewFragmentTitlebarTitleTxtView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lines="1"
            android:singleLine="true"
            android:layout_toRightOf="@+id/bsdkPublishProjectPreviewFragmentTitlebarBackBtnLayout"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
</RelativeLayout>
