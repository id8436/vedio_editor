<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/video_view_wrapper"
    android:background="@color/player_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:onClick="touchPlayer">
    <RelativeLayout
        android:id="@+id/player_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true">
        <SurfaceView
            android:id="@+id/player_surface"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/player_controls"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:onClick="touchMediaControls">
        <SeekBar
            android:id="@+id/seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/total_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="00:00"
            android:layout_below="@+id/seekbar"
            android:layout_marginEnd="10dp"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/current_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="00:00"
            android:layout_below="@+id/seekbar"
            android:layout_marginStart="10dp"
            android:layout_alignParentStart="true"/>
        <ImageView
            android:id="@+id/playpause"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_media_pause"
            android:layout_below="@+id/seekbar"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"/>
        <ImageView
            android:id="@+id/fastforward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_action_fast_forward"
            android:layout_below="@+id/seekbar"
            android:layout_toEndOf="@+id/playpause"/>
        <ImageView
            android:id="@+id/rewind"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_action_rewind"
            android:layout_below="@+id/seekbar"
            android:layout_toStartOf="@+id/playpause"/>
    </RelativeLayout>
    <LinearLayout
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:id="@+id/top_bar"
        android:paddingTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">
        <ImageView
            android:id="@+id/back_btn"
            android:layout_marginLeft="10dp"
            style="@style/backIconStyle"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/player_loading"
        android:visibility="invisible"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_centerInParent="true"/>
</RelativeLayout>
