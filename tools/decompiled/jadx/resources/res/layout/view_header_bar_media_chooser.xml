<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/postToActionBarFromMediaChooser"
        android:background="#ffffff"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:weightSum="1"
        android:layout_alignParentTop="true">
        <Button
            android:textColor="#ff6f36a0"
            android:gravity="center"
            android:id="@+id/backArrowImageViewFromMediaChooserHeaderView"
            android:background="#ffffff"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:adjustViewBounds="true"
            android:text="@string/video"
            android:drawablePadding="2dp"
            android:layout_weight="0"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:contentDescription="@null"
            android:textAllCaps="false"
            android:drawableStart="@drawable/btn_caret_backbold_2x"
            android:layout_marginStart="10dp"
            style="?android:attr/borderlessButtonStyle"/>
        <TextView
            android:textSize="19sp"
            android:textColor="#000000"
            android:ellipsize="middle"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/titleTextViewFromMediaChooserHeaderBar"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="@string/video"
            android:singleLine="true"
            android:layout_weight="1"
            android:layout_centerInParent="true"/>
        <Button
            android:gravity="center"
            android:id="@+id/DummyButton"
            android:background="#ffffff"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:adjustViewBounds="true"
            android:text="@string/video"
            android:drawablePadding="2dp"
            android:layout_weight="0"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:contentDescription="@null"
            android:textAllCaps="false"
            android:drawableStart="@drawable/btn_caret_backbold_2x"
            style="?android:attr/borderlessButtonStyle"/>
    </LinearLayout>
</FrameLayout>
