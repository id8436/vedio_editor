<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="@dimen/editor_topbar_height">
        <ImageView
            android:id="@+id/backButton_youtube"
            android:background="@drawable/ripple_effect_purple"
            android:tint="#000000"
            android:onClick="closeAndGoBack"
            style="@style/backIconStyle"/>
        <TextView
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/twitter_settings_title"
            android:layout_toRightOf="@+id/backButton_youtube"
            android:layout_centerVertical="true"/>
        <Button
            android:textColor="@color/white"
            android:id="@+id/publish_button"
            android:background="@drawable/ripple_purple_button"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/sharing_post_btn"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
    <View
        android:background="#cccccc"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@android:color/transparent"
        android:paddingLeft="20dp"
        android:paddingTop="10dp"
        android:paddingRight="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:id="@+id/publish_project_thumb"
                android:layout_width="100dp"
                android:layout_height="60dp"
                android:src="@drawable/gra_projectthumb_placeholder"
                android:layout_marginEnd="10dp"/>
            <EditText
                android:textSize="14sp"
                android:textColor="@color/black"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:id="@+id/text_desc"
                android:background="@android:color/white"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="@string/share_twitter_text"
                android:maxLength="116"/>
        </LinearLayout>
        <com.twitter.sdk.android.core.identity.TwitterLoginButton
            android:textSize="16sp"
            android:textColor="#ff6f36a0"
            android:gravity="center"
            android:id="@+id/sign_in_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/youtube_signin_text"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16sp"
                android:textColor="#ff6f36a0"
                android:id="@+id/user_name"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="10dp"
                android:layout_alignParentStart="true"/>
            <TextView
                android:textSize="16sp"
                android:textColor="#ff6f36a0"
                android:id="@+id/char_count"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="10dp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="16sp"
            android:textColor="#ff6f36a0"
            android:gravity="center"
            android:id="@+id/sign_out"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/youtube_sign_out"/>
    </LinearLayout>
</LinearLayout>
