<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/music_view"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:paddingTop="5dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <ImageView
                android:id="@+id/wave_spinner"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/btn_spinner_2x_purple"
                android:layout_centerInParent="true"/>
            <RelativeLayout
                android:id="@+id/wave_bar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/soundwave_height"/>
        </RelativeLayout>
        <RelativeLayout
            android:orientation="horizontal"
            android:background="@drawable/bottom_border"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <Button
                android:textSize="16sp"
                android:textColor="#ff6f36a0"
                android:gravity="center"
                android:id="@+id/music_replace"
                android:background="@drawable/ripple_effect_purple"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:adjustViewBounds="true"
                android:text="@string/music_replace"
                android:layout_centerVertical="true"
                android:textAllCaps="false"
                android:layout_alignParentStart="true"
                style="?android:attr/borderlessButtonStyle"/>
            <TextView
                android:textSize="15sp"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/current_track_duration"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="Starts at 0:00"
                android:lines="1"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:layout_centerInParent="true"/>
            <Button
                android:textSize="16sp"
                android:textColor="#ff6f36a0"
                android:gravity="center"
                android:id="@+id/music_delete"
                android:background="@drawable/ripple_effect_purple"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:adjustViewBounds="true"
                android:text="@string/delete_video_button"
                android:layout_centerVertical="true"
                android:textAllCaps="false"
                android:layout_alignParentEnd="true"
                style="?android:attr/borderlessButtonStyle"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bottom_border"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/music_volume"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textStyle="bold"
                    android:id="@+id/volume_percentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="70%"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <SeekBar
                android:id="@+id/volume_seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bottom_border"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <TextView
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/snap_to_beat_title"
                    android:layout_centerVertical="true"/>
                <android.support.v7.widget.SwitchCompat
                    android:id="@+id/snap_to_beat_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"/>
            </RelativeLayout>
            <TextView
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/snap_to_beat_description"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bottom_border"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <TextView
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/music_auto_mix"
                    android:layout_centerVertical="true"/>
                <android.support.v7.widget.SwitchCompat
                    android:id="@+id/audioduck_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"/>
            </RelativeLayout>
            <TextView
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_mix_description"/>
        </LinearLayout>
        <RelativeLayout
            android:background="@drawable/bottom_border"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/audio_fade_in"
                android:layout_centerVertical="true"/>
            <android.support.v7.widget.SwitchCompat
                android:id="@+id/audiofadein_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:background="@drawable/bottom_border"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/audio_fade_out"
                android:layout_centerVertical="true"/>
            <android.support.v7.widget.SwitchCompat
                android:id="@+id/audiofadeout_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"/>
        </RelativeLayout>
    </LinearLayout>
</ScrollView>
