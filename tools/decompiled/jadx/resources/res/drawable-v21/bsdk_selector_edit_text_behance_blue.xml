<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_window_focused="false"
        android:state_enabled="true">
        <nine-patch
            android:src="@drawable/bsdk_bg_material_edittext"
            android:tint="@color/bsdk_edit_text_material_design_line_color"/>
    </item>
    <item
        android:state_window_focused="false"
        android:state_enabled="false">
        <nine-patch
            android:src="@drawable/bsdk_bg_material_edittext"
            android:tint="@color/bsdk_edit_text_material_design_line_color"
            android:alpha="0.5"/>
    </item>
    <item
        android:state_focused="true"
        android:state_enabled="true">
        <nine-patch
            android:src="@drawable/bsdk_bg_material_edittext"
            android:tint="@color/bsdk_edit_text_material_design_line_focused_color"/>
    </item>
    <item
        android:state_enabled="true"
        android:state_activated="true">
        <nine-patch
            android:src="@drawable/bsdk_bg_material_edittext"
            android:tint="@color/bsdk_edit_text_material_design_line_focused_color"/>
    </item>
    <item android:state_enabled="true">
        <nine-patch
            android:src="@drawable/bsdk_bg_material_edittext"
            android:tint="@color/bsdk_edit_text_material_design_line_color"/>
    </item>
    <item android:state_focused="true">
        <nine-patch
            android:src="@drawable/bsdk_bg_material_edittext"
            android:tint="@color/bsdk_edit_text_material_design_line_color"
            android:alpha="0.5"/>
    </item>
    <item>
        <nine-patch
            android:src="@drawable/bsdk_bg_material_edittext"
            android:tint="@color/bsdk_edit_text_material_design_line_color"
            android:alpha="0.5"/>
    </item>
</selector>
